{
  "name": "alertx",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=16.0.0 <19.0.0",
    "npm": ">=8.0.0"
  },
  "scripts": {
    "setup": "node scripts/setup.js",
    "start": "cross-env NODE_OPTIONS=--openssl-legacy-provider react-native start",
    "start:reset": "cross-env NODE_OPTIONS=--openssl-legacy-provider react-native start --reset-cache",
    "android": "react-native run-android",
    "android:usb": "adb reverse tcp:8081 tcp:8081 && react-native run-android",
    "android:build": "cd android && gradlew assembleDebug && cd ..",
    "android:build:unix": "cd android && ./gradlew assembleDebug && cd ..",
    "android:release": "cd android && gradlew assembleRelease && cd ..",
    "android:release:unix": "cd android && ./gradlew assembleRelease && cd ..",
    "android:clean-build": "node scripts/clean-and-build-release.js",
    "android:install": "adb install android/app/build/outputs/apk/debug/app-debug.apk",
    "ios": "react-native run-ios",
    "test": "jest",
    "lint": "eslint ."
  },
  "dependencies": {
    "@react-navigation/bottom-tabs": "^5.11.11",
    "@react-navigation/native": "^5.9.4",
    "@react-navigation/stack": "^5.14.5",
    "graceful-fs": "^4.2.11",
    "react": "^18.1.0",
    "react-native": "^0.70.6",
    "react-native-geolocation-service": "^5.3.1",
    "react-native-gesture-handler": "^1.10.3",
    "react-native-push-notification": "^8.1.1",
    "react-native-safe-area-context": "^3.2.0",
    "react-native-screens": "^2.18.1",
    "react-native-webview": "^11.26.1",
    "uuid": "^8.3.2"
  },
  "devDependencies": {
    "@babel/core": "^7.12.10",
    "@babel/runtime": "^7.12.5",
    "@testing-library/react-native": "^9.1.0",
    "babel-jest": "^26.6.3",
    "cross-env": "^7.0.3",
    "eslint": "^7.14.0",
    "jest": "^26.6.3",
    "metro-react-native-babel-preset": "^0.66.2",
    "react-test-renderer": "17.0.2",
    "typescript": "^4.1.3"
  },
  "jest": {
    "preset": "react-native"
  }
}
